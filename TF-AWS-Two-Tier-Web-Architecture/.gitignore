
# =========================

# Terraform .gitignore

# =========================

# Local .terraform directories

.terraform/

# Terraform state files (VERY IMPORTANT - never commit)

*.tfstate
*.tfstate.*

# Crash log files

crash.log

# Exclude sensitive variable files

*.tfvars
*.tfvars.json

# Ignore override files

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files

.terraformrc
.terraform.lock.hcl
terraform.rc

# Ignore plan output files

*.tfplan

# Ignore dependency lock file (optional)

# Uncomment if you don't want to commit it

# .terraform.lock.hcl

# Ignore OS files

.DS_Store
Thumbs.db

# Ignore IDE/editor files

.vscode/
.idea/

# Ignore logs

*.log
